# ── ApplyEdge Backend — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── App ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=<generate a long random string — use: openssl rand -hex 32>
SESSION_SECRET=<generate a long random string — use: openssl rand -hex 32>

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>

# ── URLs (set these to your real deployed domain) ─────────────────────────
# If using Nginx proxy (Docker/Railway): both point to the same public domain
# Example: https://applyedge.railway.app
#
# RENDER (two services — frontend + backend):
#   Backend service env:
#     CLIENT_URL = https://YOUR-FRONTEND.onrender.com   (exact URL, no trailing slash)
#     SERVER_URL = https://YOUR-BACKEND.onrender.com
#   Frontend static site — EITHER:
#     A) Build env: REACT_APP_API_URL=https://YOUR-BACKEND.onrender.com
#        then redeploy frontend after saving the variable
#     B) Use render.yaml rewrite so /api/* proxies to the backend (see render.yaml)
CLIENT_URL=https://your-domain.com
SERVER_URL=https://your-domain.com

# ── Cloudinary ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your cloud name>
CLOUDINARY_API_KEY=<your api key>
CLOUDINARY_API_SECRET=<your api secret>

# ── Email (password reset OTP) ────────────────────────────────────────────
#
# RENDER FREE TIER: Gmail SMTP is blocked. Use Brevo (best, no domain needed):
#   1. Sign up: https://www.brevo.com (free ~300 emails/day)
#   2. Senders → Add sender → noreply.applyedge@gmail.com → verify via inbox link
#   3. SMTP & API → API Keys → create key → BREVO_API_KEY
#   4. On Render backend, set:
#        BREVO_API_KEY=xkeysib-...
#        BREVO_SENDER_EMAIL=noreply.applyedge@gmail.com
#        BREVO_SENDER_NAME=ApplyEdge
#        NODE_ENV=production
#
# Optional Resend fallback (test only without a domain):
#   RESEND_API_KEY=re_xxx
#   EMAIL_FROM=ApplyEdge <onboarding@resend.dev>
BREVO_API_KEY=xkeysib-xxxxxxxx
BREVO_SENDER_EMAIL=noreply.applyedge@gmail.com
BREVO_SENDER_NAME=ApplyEdge
RESEND_API_KEY=
EMAIL_FROM=

# Local dev (Docker/npm): uses Gmail SMTP when NODE_ENV is not production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply.applyedge@gmail.com
SMTP_PASS=<gmail app password — 16 chars>
SMTP_FROM=ApplyEdge <noreply.applyedge@gmail.com>

# ── AI ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=<your groq api key>
